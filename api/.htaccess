# 1. Protect config files from being seen by the public
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

<Files "db_config.php">
    Order Allow,Deny
    Deny from all
</Files>

# 2. Protect log files from being seen by the public
<Files "*.log">
    Order Allow,Deny
    Deny from all
</Files>

# 4. Prevent people from seeing a list of all your files
Options -Indexes
